model Company {
  id                    String        @id @default(uuid()) @db.Uuid
  name                  String
  slug                  String        @unique
  email                 String
  phone                 String?
  website               String?
  address               String?
  address2              String?
  city                  String?
  state                 String?
  country               String?       @default("KE")
  postalCode            String?
  timezone              String        @default("Africa/Nairobi")
  currency              String        @default("KES")
  logo                  String?
  primaryColor          String?
  secondaryColor        String?
  status                CompanyStatus @default(PENDING)
  settings              Json?         @default("{}")
  metadata              Json?         @default("{}")
  taxId                 String?
  registrationNumber    String?
  industry              String?
  employeeCount         Int?
  fleetSize             Int?          @default(0)
  foundedDate           DateTime?
  onboardingCompletedAt DateTime?
  trialEndsAt           DateTime?
  lastLoginAt           DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  companyUsers             CompanyUser[]
  roles                    Role[]
  userRoles                UserRole[]
  vehicleTypes             VehicleType[]
  vehicleCategories        VehicleCategory[]
  vehicles                 Vehicle[]
  drivers                  Driver[]
  trips                    Trip[]
  routes                   Route[]
  gpsDevices               GPSDevice[]
  vehicleLocations         VehicleLocation[]
  telemetryData            TelemetryData[]
  geofences                Geofence[]
  fuelLogs                 FuelLog[]
  fuelStations             FuelStation[]
  fuelSuppliers            FuelSupplier[]
  fuelCards                FuelCard[]
  fuelFraudAlerts          FuelFraudAlert[]
  vehicleFuelStats         VehicleFuelStats[]
  driverFuelStats          DriverFuelStats[]
  fuelEfficiencyBenchmarks FuelEfficiencyBenchmark[]
  odometerReadings         OdometerReading[]
  maintenanceSchedules     MaintenanceSchedule[]
  maintenanceRecords       MaintenanceRecord[]
  serviceCenters           ServiceCenter[]
  spareParts               SparePart[]
  maintenanceCosts         MaintenanceCost[]
  workOrders               WorkOrder[]
  mechanics                Mechanic[]
  serviceTemplates         ServiceTemplate[]
  vehicleDowntimes         VehicleDowntime[]
  maintenanceNotifications MaintenanceNotification[]
  vehicleDocuments         VehicleDocument[]
  driverDocuments          DriverDocument[]
  driverCertifications     DriverCertification[]
  driverMedicalRecords     DriverMedicalRecord[]
  shifts                   Shift[]
  operationalRules         OperationalRule[]
  tripCargos               TripCargo[]
  tripTimelines            TripTimeline[]
  tripChecklists           TripChecklist[]
  tripInspections          TripInspection[]
  driverBehaviors          DriverBehavior[]
  vehicleAlerts            VehicleAlert[]
  insurances               Insurance[]
  inspections              Inspection[]
  customers                Customer[]
  branches                 Branch[]
  departments              Department[]
  vehicleImages            VehicleImage[]
  invoices                 Invoice[]
  payments                 Payment[]
  expenses                 Expense[]
  notifications            Notification[]
  notificationPreferences  NotificationPreference[]
  notificationTemplates     NotificationTemplate[]
  deliveryQueues           DeliveryQueue[]
  communicationThreads     CommunicationThread[]
  auditLogs                AuditLog[]
  activityLogs             ActivityLog[]
  subscriptions            CompanySubscription[]
  apiKeys                  APIKey[]
  webhooks                 Webhook[]
  warehouses               Warehouse[]
  partCategories           PartCategory[]
  inventoryParts           InventoryPart[]
  suppliers                Supplier[]
  warehouseTransfers       WarehouseTransfer[]
  tools                    Tool[]
  inventoryAlerts          InventoryAlert[]
  stocks                   Stock[]
  stockMovements           StockMovement[]
  purchaseOrders           PurchaseOrder[]
  documentVersions         DocumentVersion[]
  complianceRules          ComplianceRule[]
  complianceChecks         ComplianceCheck[]
  complianceExceptions     ComplianceException[]
  inspectionTemplates      InspectionTemplate[]
  incidents                Incident[]
  correctiveActions        CorrectiveAction[]
  approvalWorkflows        ApprovalWorkflow[]
  approvalRequests         ApprovalRequest[]
  complianceDocuments      ComplianceDocument[]
  reports                  Report[]
  scheduledReports         ScheduledReport[]
  reportTemplates          ReportTemplate[]
  dashboardWidgets         DashboardWidget[]
  analyticsCaches          AnalyticsCache[]
  usageRecords             UsageRecord[]
  featureFlags             FeatureFlag[]
  coupons                  Coupon[]

  @@index([status])
  @@index([slug])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, deletedAt])
  @@map("companies")
}

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  email               String     @unique
  passwordHash        String
  firstName           String
  lastName            String
  phone               String?
  avatar              String?
  status              UserStatus @default(PENDING)
  emailVerifiedAt     DateTime?
  phoneVerifiedAt     DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  twoFactorEnabled    Boolean    @default(false)
  twoFactorSecret     String?
  locale              String     @default("en")
  timezone            String     @default("Africa/Nairobi")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  refreshTokens           RefreshToken[]
  sessions                Session[]
  companyUsers            CompanyUser[]
  userRoles               UserRole[]
  drivers                 Driver[]
  fleetVehicles           Vehicle[]                @relation(name: "FleetManager")
  workOrderSupervisors    WorkOrder[]              @relation(name: "WorkOrderSupervisor")
  notifications            Notification[]                @relation(name: "UserNotifications")
  notificationPreferences NotificationPreference[]  @relation(name: "UserNotificationPreferences")
  auditLogs               AuditLog[]
  activityLogs            ActivityLog[]
  apiKeys                 APIKey[]
  managedWarehouses       Warehouse[]              @relation(name: "WarehouseManager")
  performedStockMovements StockMovement[]          @relation(name: "StockMovementPerformer")
  approvedPurchaseOrders  PurchaseOrder[]          @relation(name: "PurchaseOrderApprover")
  requestedTransfers      WarehouseTransfer[]      @relation(name: "TransferRequester")
  approvedTransfers       WarehouseTransfer[]      @relation(name: "TransferApprover")
  receivedTransfers       WarehouseTransfer[]      @relation(name: "TransferReceiver")

  investigatedIncidents      Incident[]         @relation(name: "InvestigatedIncidents")
  resolvedIncidents          Incident[]         @relation(name: "ResolvedIncidents")
  assignedCorrectiveActions  CorrectiveAction[] @relation(name: "AssignedCorrectiveActions")
  completedCorrectiveActions CorrectiveAction[] @relation(name: "CompletedCorrectiveActions")
  requestedApprovals         ApprovalRequest[]  @relation(name: "RequestedApprovals")
  decidedApprovals           ApprovalRequest[]  @relation(name: "DecidedApprovals")
  reports                    Report[]
  scheduledReports           ScheduledReport[]
  reportTemplates            ReportTemplate[]
  dashboardWidgets           DashboardWidget[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, deletedAt])
  @@map("users")
}

model CompanyUser {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  companyId       String    @db.Uuid
  employeeId      String?
  department      String?
  jobTitle        String?
  hireDate        DateTime?
  terminationDate DateTime?
  isActive        Boolean   @default(true)
  isOwner         Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([companyId, isActive])
  @@index([companyId, deletedAt])
  @@index([userId, deletedAt])
  @@map("company_users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  companyId   String?  @db.Uuid
  permissions String[] // Array of permission codes

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userRoles UserRole[]

  @@unique([name, companyId])
  @@index([companyId])
  @@index([companyId, isSystem])
  @@index([companyId, deletedAt])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  name        String
  description String?
  module      String
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module])
  @@index([code, module])
  @@map("permissions")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  companyId  String   @db.Uuid
  assignedBy String?  @db.Uuid
  assignedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, companyId])
  @@index([companyId])
  @@index([companyId, userId])
  @@index([companyId, roleId])
  @@index([userId])
  @@map("user_roles")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  lastActiveAt DateTime @default(now())
  companyId    String?  @db.Uuid // Context: which company the user was viewing

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@index([createdAt])
  @@map("sessions")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?   @db.Uuid
  ipAddress  String?
  userAgent  String?
  companyId  String?   @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([userId, expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

// ============================================================================
// FLEET
// ============================================================================

model VehicleCategory {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String  @db.Uuid
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
  isCustom    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company                  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicleTypes             VehicleType[]
  vehicles                 Vehicle[]
  fuelEfficiencyBenchmarks FuelEfficiencyBenchmark[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, sortOrder])
  @@index([companyId, isActive])
  @@index([companyId, deletedAt])
  @@map("vehicle_categories")
}

model VehicleType {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String    @db.Uuid
  categoryId     String?   @db.Uuid
  name           String
  description    String?
  make           String?
  model          String?
  yearFrom       Int?
  yearTo         Int?
  capacity       Int? // Passengers
  loadCapacity   Float? // kg or tons
  fuelType       FuelType?
  fuelEfficiency Float? // km/L or mpg
  isActive       Boolean   @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category VehicleCategory? @relation(fields: [categoryId], references: [id])
  vehicles Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, categoryId])
  @@index([companyId, isActive])
  @@index([companyId, deletedAt])
  @@map("vehicle_types")
}

model Vehicle {
  id                 String              @id @default(uuid()) @db.Uuid
  companyId          String              @db.Uuid
  typeId             String?             @db.Uuid
  categoryId         String?             @db.Uuid
  registrationNumber String
  plateNumber        String?             @unique
  vin                String?
  make               String
  model              String
  trim               String?
  year               Int?
  color              String?
  category           String?
  fuelType           FuelType?
  fuelCapacity       Float? // Liters
  fuelTankCapacity   Float? // Liters
  transmission       String?
  engineCapacity     Float? // cc
  horsepower         Float?
  torque             Float? // Nm
  seatingCapacity    Int?
