  requestedBy            String?                 @db.Uuid
  approvedBy             String?                 @db.Uuid
  approvedAt             DateTime?
  receivedBy             String?                 @db.Uuid
  receivedAt             DateTime?
  notes                  String?
  totalItems             Int                     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

