# ═══════════════════════════════════════════════════════════════════════════════
# .dockerignore — Comprehensive exclusions for production Docker builds
# ═══════════════════════════════════════════════════════════════════════════════

# Git
.git
.gitignore
.gitattributes

# Node.js
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
npm-debug.log
.pnpm-debug.log*

# Next.js build output
.next
out

# Environment files (never bake secrets into images)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# Coverage & test output
coverage
*.lcov
.nyc_output
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
vitest.config.ts

# IDE / OS
.DS_Store
.vscode
.idea
*.swp
*.swo
*.swn
*~

# Documentation (not needed at runtime)
docs
*.md
DEPLOYMENT.md
CHANGELOG.md
README.md

# Tests
tests
test
__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# CI/CD configs (not needed in build)
.github
.gitlab-ci.yml
Jenkinsfile
.travis.yml

# Prettier / ESLint (used in dev, not runtime)
.prettierrc
.prettierignore
.eslintrc.json
.eslintrc.js
eslint.config.js

# PostCSS / Tailwind (processed at build time)
postcss.config.js
tailwind.config.ts

# TypeScript build info
tsconfig.tsbuildinfo

# Docker files themselves (avoid recursive copy issues)
Dockerfile
Dockerfile.dev
.dockerignore
docker-compose.yml
docker-compose.*.yml

# Scripts (not needed at runtime — use docker exec for DB ops)
scripts

# Monitoring configs (mounted as volumes, not copied)
monitoring

# Misc
.next-env.d.ts
