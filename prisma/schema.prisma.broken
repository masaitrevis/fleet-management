// Fleet Management SaaS - Prisma Schema
// Phase 2: Database Design
// PostgreSQL 15+ with Prisma ORM 5.x
// Multi-tenant, production-ready, scalable

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "typedSql"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL") // For migrations, bypass connection pooler
  extensions = [pgcrypto]
}

