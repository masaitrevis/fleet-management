// ============================================================================
// DOCUMENTS, COMPLIANCE & INSPECTIONS
// ============================================================================

// Additional DocumentType values already exist in DocumentType enum
// Need to add: LEASING_AGREEMENT, OWNERSHIP_DOCUMENTS

enum InspectionType {
  DAILY_VEHICLE
  PRE_TRIP
  POST_TRIP
  ANNUAL
  SAFETY
  WORKSHOP
  REGULATORY
  CUSTOM
}

enum IncidentType {
  TRAFFIC_VIOLATION
  VEHICLE_DAMAGE
  ACCIDENT
  SAFETY_INCIDENT
  DRIVER_MISCONDUCT
  COMPLIANCE_VIOLATION
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum ComplianceRuleType {
  VEHICLE_INSURANCE
  VEHICLE_INSPECTION
  VEHICLE_REGISTRATION
  DRIVER_LICENSE
  DRIVER_MEDICAL
  DRIVER_TRAINING
  CUSTOM
}

enum ComplianceRuleStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum CorrectiveActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DocumentStatus {
  ACTIVE
  EXPIRED
  EXPIRING_SOON
  PENDING_RENEWAL
  SUSPENDED
}

enum ComplianceCheckStatus {
  PASS
  FAIL
  WARNING
  NOT_APPLICABLE
}

model DocumentVersion {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @db.Uuid
  vehicleDocId  String?  @db.Uuid
  driverDocId   String?  @db.Uuid
  versionNumber Int      @default(1)
  fileUrl       String
  fileName      String?
  fileSize      Int?
  mimeType      String?
  notes         String?
  createdBy     String?  @db.Uuid
  createdAt     DateTime @default(now())

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicleDoc VehicleDocument? @relation(fields: [vehicleDocId], references: [id], onDelete: Cascade)
  driverDoc  DriverDocument?  @relation(fields: [driverDocId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([vehicleDocId])
  @@index([driverDocId])
  @@index([companyId, createdAt])
  @@map("document_versions")
}

model ComplianceRule {
  id              String               @id @default(uuid()) @db.Uuid
  companyId       String               @db.Uuid
  ruleType        ComplianceRuleType
  name            String
  description     String?
  appliesTo       String // VEHICLE, DRIVER, BOTH
  documentType    DocumentType?
  inspectionType  InspectionType?
  gracePeriodDays Int                  @default(0)
  isMandatory     Boolean              @default(true)
  isBlocking      Boolean              @default(true) // If true, blocks operations
  autoRenewal     Boolean              @default(false)
  reminderDays    Int[]                @default([30, 7, 1])
  status          ComplianceRuleStatus @default(ACTIVE)
  priority        Int                  @default(1)
  customLogic     String? // JSON or code snippet for custom rules
  failureAction   String? // BLOCK, WARN, NOTIFY

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company    Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  checks     ComplianceCheck[]
  exceptions ComplianceException[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, ruleType])
  @@index([companyId, deletedAt])
  @@map("compliance_rules")
}

model ComplianceCheck {
  id            String                @id @default(uuid()) @db.Uuid
  companyId     String                @db.Uuid
  ruleId        String                @db.Uuid
  vehicleId     String?               @db.Uuid
  driverId      String?               @db.Uuid
  documentId    String?               @db.Uuid
  inspectionId  String?               @db.Uuid
  status        ComplianceCheckStatus
  checkedAt     DateTime              @default(now())
  expiresAt     DateTime?
  notes         String?
  failureReason String?
  autoGenerated Boolean               @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rule       ComplianceRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  vehicle    Vehicle?         @relation(fields: [vehicleId], references: [id])
  driver     Driver?          @relation(fields: [driverId], references: [id])
  document   VehicleDocument? @relation(fields: [documentId], references: [id])
  inspection Inspection?      @relation(fields: [inspectionId], references: [id])

  @@index([companyId])
  @@index([companyId, vehicleId])
  @@index([companyId, driverId])
  @@index([companyId, status])
  @@index([companyId, deletedAt])
  @@index([vehicleId, status])
  @@index([driverId, status])
  @@map("compliance_checks")
}

model ComplianceException {
