model Incident {
  id             String           @id @default(uuid()) @db.Uuid
  companyId      String           @db.Uuid
  incidentNumber String           @unique
  incidentType   IncidentType
  severity       IncidentSeverity
  status         IncidentStatus   @default(OPEN)

  // Related entities
  vehicleId String? @db.Uuid
  driverId  String? @db.Uuid
  tripId    String? @db.Uuid

  // Incident details
  title        String
  description  String?
  incidentDate DateTime
  incidentTime String?
  location     String?
  latitude     Float?
  longitude    Float?

  // Damage/Cost
  vehicleDamage  String?
  estimatedCost  Float?
  actualCost     Float?
  insuranceClaim Boolean @default(false)
  claimNumber    String?

  // Investigation
  investigatedBy     String?   @db.Uuid
  investigationNotes String?
  rootCause          String?
  resolution         String?
  resolvedAt         DateTime?
  resolvedBy         String?   @db.Uuid

  // Penalties
  fineAmount    Float?
  penaltyPoints Int?
  legalAction   Boolean   @default(false)
  courtDate     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company           Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicle           Vehicle?             @relation(fields: [vehicleId], references: [id])
  driver            Driver?              @relation(fields: [driverId], references: [id])
  trip              Trip?                @relation(fields: [tripId], references: [id])
  investigator      User?                @relation(fields: [investigatedBy], references: [id], name: "InvestigatedIncidents")
  resolver          User?                @relation(fields: [resolvedBy], references: [id], name: "ResolvedIncidents")
  attachments       IncidentAttachment[]
  correctiveActions CorrectiveAction[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, incidentType])
  @@index([companyId, severity])
  @@index([companyId, vehicleId])
  @@index([companyId, driverId])
  @@index([companyId, incidentDate])
  @@index([companyId, deletedAt])
  @@index([incidentNumber])
  @@map("incidents")
}

model IncidentAttachment {
  id          String   @id @default(uuid()) @db.Uuid
  incidentId  String   @db.Uuid
  fileUrl     String
  fileName    String?
  fileSize    Int?
  mimeType    String?
  description String?
  uploadedBy  String?  @db.Uuid
  createdAt   DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_attachments")
}

model CorrectiveAction {
  id                String  @id @default(uuid()) @db.Uuid
  companyId         String  @db.Uuid
  incidentId        String? @db.Uuid
  vehicleId         String? @db.Uuid
  driverId          String? @db.Uuid
  complianceCheckId String? @db.Uuid

  title       String
  description String?
  assignedTo  String?                @db.Uuid
  dueDate     DateTime?
  completedAt DateTime?
  completedBy String?                @db.Uuid
  status      CorrectiveActionStatus @default(PENDING)
  priority    Int                    @default(1)
  notes       String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  incident  Incident? @relation(fields: [incidentId], references: [id])
  vehicle   Vehicle?  @relation(fields: [vehicleId], references: [id])
  driver    Driver?   @relation(fields: [driverId], references: [id])
  assignee  User?     @relation(fields: [assignedTo], references: [id], name: "AssignedCorrectiveActions")
  completer User?     @relation(fields: [completedBy], references: [id], name: "CompletedCorrectiveActions")

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, incidentId])
  @@index([companyId, assignedTo])
  @@index([companyId, dueDate])
  @@index([companyId, deletedAt])
  @@map("corrective_actions")
}

model ApprovalWorkflow {
  id           String  @id @default(uuid()) @db.Uuid
  companyId    String  @db.Uuid
  name         String
  description  String?
  workflowType String // DOCUMENT, INSPECTION, CORRECTIVE_ACTION, EXCEPTION
  isActive     Boolean @default(true)
  isDefault    Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps    ApprovalStep[]
  requests ApprovalRequest[]

  @@index([companyId])
  @@index([companyId, workflowType])
  @@index([companyId, isActive])
  @@index([companyId, deletedAt])
  @@map("approval_workflows")
}

model ApprovalStep {
  id             String  @id @default(uuid()) @db.Uuid
  workflowId     String  @db.Uuid
  stepNumber     Int
  name           String
  approverId     String? @db.Uuid // Specific user
  approverRoleId String? @db.Uuid // Role-based
  requiresAll    Boolean @default(false) // If true, all matching approvers must approve

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([workflowId, stepNumber])
  @@map("approval_steps")
}

model ApprovalRequest {
  id          String @id @default(uuid()) @db.Uuid
  companyId   String @db.Uuid
  workflowId  String @db.Uuid
  requesterId String @db.Uuid

  // What is being approved
  entityType String // DOCUMENT, INSPECTION, CORRECTIVE_ACTION, EXCEPTION
  entityId   String @db.Uuid

  status      ApprovalStatus @default(PENDING)
  currentStep Int            @default(1)

  notes         String?
  decidedAt     DateTime?
  decidedBy     String?   @db.Uuid
  decisionNotes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workflow  ApprovalWorkflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  requester User                  @relation(fields: [requesterId], references: [id], name: "RequestedApprovals")
  decider   User?                 @relation(fields: [decidedBy], references: [id], name: "DecidedApprovals")
  steps     ApprovalRequestStep[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, entityType])
  @@index([companyId, deletedAt])
  @@map("approval_requests")
}

model ApprovalRequestStep {
  id         String         @id @default(uuid()) @db.Uuid
  requestId  String         @db.Uuid
  stepNumber Int
  approverId String         @db.Uuid
  status     ApprovalStatus @default(PENDING)
  notes      String?
  decidedAt  DateTime?

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([requestId, stepNumber])
  @@map("approval_request_steps")
}

model ComplianceDocument {
  id           String  @id @default(uuid()) @db.Uuid
  companyId    String  @db.Uuid
  title        String
  description  String?
  documentType String
  fileUrl      String
  fileName     String?
  fileSize     Int?
  mimeType     String?
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, documentType])
  @@index([companyId, deletedAt])
  @@map("compliance_documents")
}

