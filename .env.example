# ═══════════════════════════════════════════════════════════════════════════════
# Environment Variables — Fleet Management SaaS
# Copy this file to .env.development, .env.staging, or .env.production
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE (Required)
# ───────────────────────────────────────────────────────────────────────────────
# Main connection string for Prisma Client
DATABASE_URL="postgresql://user:password@localhost:5432/fleet_management?schema=public"
# Direct connection for Prisma Migrate / DB push (no connection pool)
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/fleet_management?schema=public"

# ───────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (Required)
# ───────────────────────────────────────────────────────────────────────────────
# JWT signing secrets — use strong random strings in production (min 64 chars)
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-64-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-64-chars"
# Token expiration in seconds (900 = 15 min, 604800 = 7 days)
JWT_EXPIRES_IN="900"
JWT_REFRESH_EXPIRES_IN="604800"

# ───────────────────────────────────────────────────────────────────────────────
# APP CONFIGURATION (Required)
# ───────────────────────────────────────────────────────────────────────────────
# Public-facing URL (used in emails, redirects, absolute URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Internal app URL (used for server-side fetch, webhooks)
APP_URL="http://localhost:3000"
# API base path (used by frontend)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ───────────────────────────────────────────────────────────────────────────────
# CLOUDINARY (Required for image uploads)
# ───────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ───────────────────────────────────────────────────────────────────────────────
# EMAIL (Required for notifications, password reset, invites)
# ───────────────────────────────────────────────────────────────────────────────
# Resend API key (recommended — https://resend.com)
RESEND_API_KEY=""
# SMTP fallback settings (only used if Resend is not configured)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Default sender email address
FROM_EMAIL="noreply@yourdomain.com"
FROM_NAME="Fleet Management"

# ───────────────────────────────────────────────────────────────────────────────
# M-PESA (Safaricom) — Required for payment processing
# ───────────────────────────────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE=""
# sandbox | production
MPESA_ENV="sandbox"
# Must be HTTPS in production for M-Pesa callbacks to work
MPESA_CALLBACK_URL=""

# ───────────────────────────────────────────────────────────────────────────────
# REDIS (Optional but recommended for rate limiting, caching, sessions)
# ───────────────────────────────────────────────────────────────────────────────
REDIS_URL=""
# Redis connection pool size (default: 10)
REDIS_POOL_SIZE="10"

# ───────────────────────────────────────────────────────────────────────────────
# MONITORING (Optional)
# ───────────────────────────────────────────────────────────────────────────────
# Sentry DSN for error tracking
SENTRY_DSN=""
# Grafana admin credentials (for Docker Compose monitoring stack)
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="change-me-in-production"

# ───────────────────────────────────────────────────────────────────────────────
# SECURITY (Optional but recommended)
# ───────────────────────────────────────────────────────────────────────────────
# Enable/disable 2FA enforcement for admin accounts
ADMIN_2FA_REQUIRED="false"
# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=""
# Session secret for cookie signing (fallback if not using JWT)
SESSION_SECRET=""
# Max upload size in MB
MAX_UPLOAD_SIZE_MB="10"
# Enable request logging (true | false)
LOG_REQUESTS="true"
# Log level (debug | info | warn | error)
LOG_LEVEL="info"
