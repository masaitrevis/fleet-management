model WarehouseTransferItem {
  id               String  @id @default(uuid()) @db.Uuid
  transferId       String  @db.Uuid
  partId           String? @db.Uuid
  quantity         Int
  receivedQuantity Int     @default(0)
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transfer WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  part     InventoryPart?    @relation(fields: [partId], references: [id])

  @@index([transferId])
  @@index([transferId, partId])
  @@map("warehouse_transfer_items")
}

model Tool {
  id                  String        @id @default(uuid()) @db.Uuid
  companyId           String        @db.Uuid
  toolNumber          String
  name                String
  description         String?
  serialNumber        String?
  model               String?
  manufacturer        String?
  purchaseDate        DateTime?
  purchasePrice       Float?
  assignedMechanicId  String?       @db.Uuid
  lastCalibrationDate DateTime?
  nextCalibrationDate DateTime?
  status              ToolStatus    @default(AVAILABLE)
  condition           ToolCondition @default(EXCELLENT)
  location            String?
  imageUrl            String?
  notes               String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mechanic Mechanic? @relation(fields: [assignedMechanicId], references: [id])

  @@unique([companyId, toolNumber])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, assignedMechanicId])
  @@index([companyId, deletedAt])
  @@index([deletedAt])
  @@map("tools")
}

model InventoryAlert {
  id              String             @id @default(uuid()) @db.Uuid
  companyId       String             @db.Uuid
  alertType       InventoryAlertType
  title           String
  message         String
  partId          String?            @db.Uuid
  warehouseId     String?            @db.Uuid
  purchaseOrderId String?            @db.Uuid
  isRead          Boolean            @default(false)
  isResolved      Boolean            @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  part          InventoryPart? @relation(fields: [partId], references: [id])
  warehouse     Warehouse?     @relation(fields: [warehouseId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([companyId])
  @@index([companyId, isRead])
  @@index([companyId, isResolved])
  @@index([companyId, alertType])
  @@index([companyId, deletedAt])
  @@index([deletedAt])
  @@map("inventory_alerts")
}


// ============================================================================

// ============================================================================
// PHASE 15: REPORTS, ANALYTICS & BUSINESS INTELLIGENCE
// ============================================================================

enum ReportType {
  FLEET
  DRIVER
  TRIP
  GPS
  FUEL
  MAINTENANCE
  INVENTORY
  COMPLIANCE
  FINANCIAL
  CUSTOM
}

enum ReportFormat {
  CSV
  EXCEL
  PDF
  JSON
  HTML
}

enum ReportCategory {
  FLEET
  DRIVER
  TRIP
  GPS
  FUEL
  MAINTENANCE
  INVENTORY
  COMPLIANCE
  FINANCIAL
  EXECUTIVE
  OPERATIONS
  CUSTOM
}

enum ScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  CUSTOM
}

enum WidgetType {
  KPI_CARD
  LINE_CHART
  BAR_CHART
  PIE_CHART
  DOUGHNUT_CHART
  AREA_CHART
  HEATMAP
  TABLE
  GAUGE
  STAT
  TREND
  GEO_MAP
}

enum ChartType {
  LINE
  BAR
  PIE
  DOUGHNUT
  AREA
  HEATMAP
  SCATTER
  RADAR
  GAUGE
  TABLE
  GEO_MAP
  STAT
  TREND
}

model Report {
  id          String        @id @default(uuid()) @db.Uuid
  companyId   String        @db.Uuid
  name        String
  type        ReportType
  category    ReportCategory
  description String?
  filters     Json          @default("{}")
  parameters  Json          @default("{}")
  data        Json?
  result      Json?
  summary     Json?
  format      ReportFormat  @default(JSON)
  fileUrl     String?
  fileSize    Int?
  isScheduled Boolean       @default(false)
  status      String        @default("COMPLETED") // PENDING, PROCESSING, COMPLETED, FAILED
  errorMessage String?
  startDate   DateTime?
  endDate     DateTime?
  generatedBy String?       @db.Uuid
  generatedAt DateTime?
  expiresAt   DateTime?
  metadata    Json?         @default("{}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator   User?     @relation(fields: [generatedBy], references: [id])
  scheduledReports ScheduledReport[]

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, category])
  @@index([companyId, status])
  @@index([companyId, generatedBy])
  @@index([companyId, deletedAt])
  @@index([deletedAt])
  @@index([companyId, createdAt])
  @@map("reports")
}

model ScheduledReport {
  id          String             @id @default(uuid()) @db.Uuid
  companyId   String             @db.Uuid
  reportId    String             @db.Uuid
  name        String
  type        ReportType
  category    ReportCategory
  description String?
  filters     Json               @default("{}")
  parameters  Json               @default("{}")
  format      ReportFormat       @default(PDF)
  frequency   ScheduleFrequency
  scheduleDay Int?               // Day of week/month for scheduling
  scheduleTime String            @default("09:00")
  timezone    String             @default("Africa/Nairobi")
  recipients  Json?              @default("[]")
  emailSubject String?
  emailBody   String?
  isActive    Boolean            @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  runCount    Int                @default(0)
  successCount Int               @default(0)
  failureCount Int               @default(0)
  lastError   String?
  createdById String? @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  report    Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([companyId, isActive])
  @@index([companyId, nextRunAt])
  @@index([companyId, deletedAt])
  @@index([deletedAt])
  @@map("scheduled_reports")
}

model ReportTemplate {
  id          String         @id @default(uuid()) @db.Uuid
  companyId   String         @db.Uuid
  name        String
  type        ReportType
  category    ReportCategory
  description String?
  filters     Json           @default("{}")
  parameters  Json           @default("{}")
  columns     Json?          @default("[]")
  defaultFormat ReportFormat @default(PDF)
  isDefault   Boolean        @default(false)
  isSystem    Boolean        @default(false)
  isActive    Boolean        @default(true)
  sortBy      String?
  sortOrder   String?        @default("desc")
  groupBy     String?
  metadata    Json?          @default("{}")
  createdById String? @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, category])
  @@index([companyId, isSystem])
  @@index([companyId, deletedAt])
  @@index([deletedAt])
  @@map("report_templates")
}

model DashboardWidget {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @db.Uuid
  userId      String?    @db.Uuid
  name        String
  type        WidgetType
  title       String
  subtitle    String?
  description String?
  dataSource  String?    // e.g., "fleet.vehicle_count", "fuel.consumption"
  filters     Json       @default("{}")
  parameters  Json       @default("{}")
  config      Json       @default("{}") // chart options, colors, etc.
  position    Json?      @default("{}") // x, y, w, h for grid layout
  size        String?    @default("medium") // small, medium, large
  refreshInterval Int?   @default(300) // seconds
  isVisible   Boolean    @default(true)
  isPinned    Boolean    @default(false)
  sortOrder   Int        @default(0)
  dashboard   String?    @default("main") // dashboard identifier
  lastData    Json?      @default("{}")
  lastRefreshedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([companyId, userId])
  @@index([companyId, dashboard])
  @@index([companyId, type])
  @@index([companyId, deletedAt])
  @@index([deletedAt])
  @@map("dashboard_widgets")
}

model AnalyticsCache {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @db.Uuid
  key         String    // cache key e.g., "fleet_kpis_2024-01"
  category    String    // FLEET, DRIVER, FUEL, etc.
  subcategory String?   // e.g., "utilization", "safety"
  data        Json
  metadata    Json?     @default("{}")
  expiresAt   DateTime

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([companyId])
  @@index([companyId, category])
  @@index([companyId, key])
  @@index([expiresAt])
  @@map("analytics_cache")
}

// ============================================================================
// BILLING & SUBSCRIPTION (Phase 16)
// ============================================================================

model UsageRecord {
  id          String      @id @default(uuid()) @db.Uuid
  companyId   String      @db.Uuid
  resourceType String     // VEHICLE, DRIVER, USER, BRANCH, WAREHOUSE, GPS_DEVICE, API_REQUEST, STORAGE, REPORT, NOTIFICATION
  currentUsage Int       @default(0)
  limitValue   Int?
  periodStart  DateTime
  periodEnd    DateTime
  isExceeded   Boolean    @default(false)
  exceededAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, resourceType, periodStart])
  @@index([companyId])
  @@index([companyId, resourceType])
  @@index([companyId, isExceeded])
  @@index([companyId, periodEnd])
  @@map("usage_records")
}

model FeatureFlag {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String  @db.Uuid
  featureKey  String  // gps_tracking, route_optimization, predictive_maintenance, bi_reports, fuel_analytics, api_access, mobile_app, white_labeling, integrations
  isEnabled   Boolean @default(false)
  config      Json?   @default("{}")
  enabledAt   DateTime?
  disabledAt  DateTime?
  enabledBy   String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, featureKey])
  @@index([companyId])
  @@index([companyId, isEnabled])
  @@index([companyId, featureKey])
  @@map("feature_flags")
}

model Coupon {
  id              String          @id @default(uuid()) @db.Uuid
  companyId       String?         @db.Uuid
  code            String          @unique
  description     String?
  discountType    DiscountType    @default(PERCENTAGE)
  discountValue   Float
  maxUses         Int?
  usedCount       Int             @default(0)
  minAmount       Float?
  applicablePlans String[]        // Array of plan slugs, empty = all plans
  startDate       DateTime
  endDate         DateTime?
  isActive        Boolean         @default(true)
  isPublic        Boolean         @default(true)
  isReferral      Boolean         @default(false)
  referredBy      String?         @db.Uuid
  referralReward  Float?          // Amount credited to referrer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  company Company? @relation(fields: [companyId], references: [id])
  usages CouponUsage[]

  @@index([companyId])
  @@index([isActive])
  @@index([isActive, isPublic])
  @@index([startDate, endDate])
  @@index([deletedAt])
  @@map("coupons")
}

model CouponUsage {
  id          String   @id @default(uuid()) @db.Uuid
  couponId    String   @db.Uuid
  companyId   String   @db.Uuid
  invoiceId   String?  @db.Uuid
  discountAmount Float
  appliedAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([companyId])
  @@index([invoiceId])
  @@map("coupon_usages")
}

// ============================================================================
// PHASE 18: PLATFORM ADMINISTRATION
// ============================================================================

enum PlatformUserRole {
  SUPER_ADMIN
  SUPPORT
  SALES
  FINANCE
  ENGINEER
}

enum PlatformUserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}

enum JobType {
  EMAIL
  SMS
  NOTIFICATION
  REPORT
  BACKUP
  CLEANUP
  CUSTOM
}

enum SecurityEventType {
  FAILED_LOGIN
  SUSPICIOUS_ACTIVITY
  RATE_LIMIT_VIOLATION
  IP_BLOCKED
  API_KEY_VIOLATION
  PRIVILEGE_ESCALATION
  DATA_EXPORT
  IMPERSONATION
}

enum SecurityEventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum BackupType {
  MANUAL
  SCHEDULED
  AUTO
}

model PlatformUser {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              PlatformUserRole   @default(SUPPORT)
  status            PlatformUserStatus @default(ACTIVE)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  failedLoginAttempts Int              @default(0)
  lockedUntil       DateTime?
  twoFactorEnabled  Boolean            @default(false)
  twoFactorSecret   String?
  avatar            String?
  phone             String?
  locale            String             @default("en")
  timezone          String             @default("Africa/Nairobi")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, deletedAt])
  @@map("platform_users")
}

model PlatformConfig {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       String
  category    String   @default("general")
  description String?
  isEncrypted Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([key, category])
  @@map("platform_config")
}

model SecurityEvent {
  id          String               @id @default(uuid()) @db.Uuid
  type        SecurityEventType
  severity    SecurityEventSeverity @default(MEDIUM)
  userId      String?              @db.Uuid
  companyId   String?              @db.Uuid
  ipAddress   String?
  userAgent   String?
  details     String?
  metadata    Json?                @default("{}")
  resolvedAt  DateTime?
  resolvedBy  String?              @db.Uuid

  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([userId])
  @@index([companyId])
  @@index([ipAddress])
  @@index([createdAt])
  @@index([type, severity])
  @@index([companyId, createdAt])
  @@index([resolvedAt])
  @@map("security_events")
}

model FailedLogin {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  ipAddress String?
  userAgent String?
  reason    String?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
  @@index([email, createdAt])
  @@map("failed_logins")
}

model RateLimitViolation {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  endpoint   String?
  limit      Int
  actual     Int
  window     Int
  ipAddress  String?

  createdAt DateTime @default(now())

  @@index([identifier])
  @@index([ipAddress])
  @@index([createdAt])
  @@index([endpoint])
  @@map("rate_limit_violations")
}

model JobRecord {
  id           String    @id @default(uuid()) @db.Uuid
  type         JobType
  status       JobStatus @default(PENDING)
  queue        String    @default("default")
  payload      Json?     @default("{}")
  result       Json?     @default("{}")
  error        String?
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  failedAt     DateTime?
  retryAt      DateTime?
  workerId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([queue])
  @@index([workerId])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([type, status])
  @@map("job_records")
}

model BackupRecord {
  id          String       @id @default(uuid()) @db.Uuid
  type        BackupType   @default(MANUAL)
  status      BackupStatus @default(PENDING)
  size        Int?         @default(0)
  path        String?
  provider    String?      @default("local")
  metadata    Json?        @default("{}")
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdBy   String?      @db.Uuid
  restoredAt  DateTime?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([type])
  @@index([provider])
  @@index([createdAt])
  @@index([createdBy])
  @@map("backup_records")
}

model PlatformAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @db.Uuid
  action      String
  entityType  String
  entityId    String?  @db.Uuid
  details     String?
  oldValues   Json?    @default("{}")
  newValues   Json?    @default("{}")
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("platform_audit_logs")
}

